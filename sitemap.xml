---
layout: none
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% for node in site.html_pages %}
  {% assign skip_node = false %}
  {% if node.url contains '/available/' or node.url contains '/join/' %}
    {% assign skip_node = true %}
  {% endif %}
  {% if node.product_slug %}
    {% assign product = site.data.products.products | where: "slug", node.product_slug | first %}
    {% if product.hidden == true %}
      {% assign skip_node = true %}
    {% endif %}
  {% endif %}
  {% unless skip_node %}
  <url>
    <loc>{{ node.url | absolute_url }}</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </url>
  {% endunless %}
{% endfor %}
</urlset>
